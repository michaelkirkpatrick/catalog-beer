# Deny all direct HTTP access to this directory.
# PHP files here are loaded by the application via require_once;
# they should never be reachable from the web.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
