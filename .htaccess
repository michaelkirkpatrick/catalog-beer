RewriteEngine On

# Never web content: docs, database dumps, shell scripts, data exports.
# deploy.sh excludes most of these, but rsync's --delete deliberately PROTECTS
# excluded files on the receiver -- so anything published before an exclusion
# existed stays on disk, served, until removed by hand. Found live during the
# 2026-07-22 audit: michaelandmollie.baby/invites.csv (27 guests' names and
# email addresses, HTTP 200) and mekstudios.com/irrigation-logs/api-smoke-test.sh.
# Deny at the server too: immediate, and it covers whatever lands here later.
<FilesMatch "\.(md|sql|sh|csv)$">
	Require all denied
</FilesMatch>

# Deny Access to Folder Indexes
Options -Indexes

# Down for Maintenance (manual toggle — uncomment, set your IP, then test)
# RewriteCond %{REQUEST_URI} !\.(css|ico|jpg|js|png)$
# My IP Address for testing
# RewriteCond %{REMOTE_ADDR} !^111\.111\.111\.111$
# RewriteRule .* /error_page/503.php [L]

# Redirect Error Pages (uncomment to let Apache serve these on server-level
# errors; only the pages that exist are listed — error_page/404.php, 503.php)
# ErrorDocument 404 /error_page/404.php
# ErrorDocument 503 /error_page/503.php

# Clean URLs
RewriteRule ^account/?$ 	account.php [L]
RewriteRule ^api-docs/?$	api-docs.php	[L]
RewriteRule ^api-usage/?$	api-usage.php	[L]
RewriteRule ^contact/?$		contact.php	[L]
RewriteRule ^login/?$ 		login.php [L]
RewriteRule ^logout/?$ 		logout.php [L]
RewriteRule ^privacy/?$		privacy.php	[L]
RewriteRule ^signup/?$		create-account.php [L]
RewriteRule ^terms/?$		terms.php	[L]
RewriteRule ^whats-new/?$	whats-new.php	[L]
RewriteRule ^build-info/?$	build-info.php	[L]

# Admin
RewriteRule ^admin/error-log/?$	admin/error-log.php	[L]


# Redirect Pages
RewriteRule ^beer/add/([-0-9a-f]{36})$ beer-add.php?brewerID=$1 [L]
RewriteRule ^beer/([-0-9a-f]{36})/edit$ beer-edit.php?beerID=$1 [L]
RewriteRule ^beer/([-0-9a-f]{36})$ beer.php?beerID=$1 [L]
RewriteRule ^beer/?$ beer-list.php [L]

RewriteRule ^brewer/([-0-9a-f]{36})/add-location$ location-add.php?brewerID=$1 [L]
RewriteRule ^brewer/([-0-9a-f]{36})/edit$ brewer-edit.php?brewerID=$1 [L]
RewriteRule ^brewer/([-0-9a-f]{36})$ brewer.php?brewerID=$1 [L]
RewriteRule ^brewer/add$ brewer-add.php [L]
RewriteRule ^brewer/?$ brewer-list.php [L]
RewriteRule ^map/?$ brewery-map.php [L]

RewriteRule ^style/?$ style-list.php [L]
RewriteRule ^style/family/([-0-9a-z]{1,64})/?$ style-family.php?parentSlug=$1 [L]
RewriteRule ^style/([-0-9a-z]{1,64})/?$ style.php?styleID=$1 [L]

RewriteRule ^location/([-0-9a-f]{36})/add-address$ address-add.php?locationID=$1 [L]
RewriteRule ^location/([-0-9a-f]{36})/delete$ location-delete.php?locationID=$1 [L]
RewriteRule ^location/([-0-9a-f]{36})/edit$ location-edit.php?locationID=$1 [L]
RewriteRule ^location/([-0-9a-f]{36})/edit-address$ address-edit.php?locationID=$1 [L]
RewriteRule ^location/([-0-9a-f]{36})/?$ brewer-list.php [L]
RewriteRule ^location/?$ brewer-list.php [L]

RewriteRule ^verify-email(\/[-0-9a-f]{36})?$ verify-email.php?emailAuth=$1 [L]

