
# OS
.DS_Store

# Credentials
config/passwords.php

# Database dumps — contain user emails, password hashes, and live API keys.
# This repo is PUBLIC. Never commit one.
*.sql

# Generated at deploy time
config/version.php

# Generated on the server by generate-sitemap.php (cron)
sitemap*.xml

# Private keys
*.p8

# Server log excerpts pulled down for review (also rsync-excluded in deploy.sh)
php-errors-*.txt

# IDE
.nova/
.editorconfig

# Legacy
classes/_notes/dwsync.xml
_notes/dwsync.xml

# Scratch space: local working files (dumps, exports, one-off scripts, notes).
# Contents are ignored by git AND excluded from rsync in deploy.sh, so nothing
# here can reach a server. Keep the directory itself tracked via .gitkeep so a
# fresh clone has somewhere obvious to put this stuff.
scratch/*
!scratch/.gitkeep

# Deploy targets (server addresses + SSH user). See deploy.conf.example.
deploy.conf
